<Window x:Class="GestorProductosWPF.AgregarProductoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestorProductosWPF"
        mc:Ignorable="d"
        Title="AgregarProductoWindow" Height="450" Width="800">
    <Grid Background="#FFEEE8DC">
        <TextBox x:Name="txtId" HorizontalAlignment="Left" Margin="31,44,0,0" TextWrapping="Wrap" Text="Id" VerticalAlignment="Top" Width="313" Height="31"/>
        <TextBox x:Name="txtNombre" HorizontalAlignment="Left" Margin="31,155,0,0" TextWrapping="Wrap" Text="Nombre" VerticalAlignment="Top" Width="313" Height="31"/>
        <TextBox x:Name="txtCategoria" HorizontalAlignment="Left" Margin="31,215,0,0" TextWrapping="Wrap" Text="Categoria" VerticalAlignment="Top" Width="313" Height="31"/>
        <TextBox x:Name="txtPrecio" HorizontalAlignment="Left" Margin="31,273,0,0" TextWrapping="Wrap" Text="Precio" VerticalAlignment="Top" Width="313" Height="31"/>
        <TextBox x:Name="txtStock" HorizontalAlignment="Left" Margin="31,329,0,0" TextWrapping="Wrap" Text="Stock" VerticalAlignment="Top" Width="313" Height="31"/>
        <TextBox x:Name="txtCodigoBarras" HorizontalAlignment="Left" Margin="31,100,0,0" TextWrapping="Wrap" Text="Codigo Barras" VerticalAlignment="Top" Width="313" Height="31"/>
        <Button x:Name="btnGuardar" Content="Guardar" HorizontalAlignment="Left" Margin="484,0,0,0" VerticalAlignment="Center" Height="57" Width="135" Click="btnGuardar_Click"/>

    </Grid>
</Window>
